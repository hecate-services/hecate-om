%% Generated by relx into the release at build time; ${VAR} placeholders
%% are substituted at boot from the runtime env.
%%
%% Required env vars (set at deploy time):
%%   HECATE_DATA_DIR     On-disk root for this service's reckon-db store
%%                       (e.g. "/var/lib/{{service_name}}").
%%
%% Canonical CMD/PRJ wiring per
%% hecate-social/hecate-agents/skills/ANTIPATTERNS_EVENT_SOURCING.md.
%% If this service is producer-only (no store), delete the reckon_db
%% and evoq blocks below + remove store_id/0 + data_dir/0 from
%% {{erlang_service_module}}.erl.

[
    {{{erlang_app_name}}, [
        {data_dir,        "${HECATE_DATA_DIR}"},
        {event_store_id,  {{erlang_app_name}}_store}
    ]},

    {hecate_om, [
        {service_cert_path, "/etc/hecate/secrets/service-cert.pem"},
        {station_socket,    "/run/macula/station.sock"},
        {health_port,       8470}
    ]},

    %% Reckon-db pool defaults. The domain starts its store in
    %% hecate_om:boot/1 via the optional store_id/0 + data_dir/0
    %% service callbacks; DO NOT put a {stores, [...]} list here.
    {reckon_db, [
        {writer_pool_size, 5},
        {reader_pool_size, 5},
        {gateway_pool_size, 1}
    ]},

    %% Evoq + reckon_evoq adapter wiring. Required when the service
    %% uses evoq aggregates with a reckon-db backend; without it,
    %% evoq crashes on first dispatch with
    %% {not_configured, event_store_adapter}.
    {evoq, [
        {event_store_adapter, reckon_evoq_adapter},
        {subscription_adapter, reckon_evoq_adapter},
        {store_id, {{erlang_app_name}}_store},
        {consistency, eventual}
    ]},

    {kernel, [
        {logger_level, info}
    ]}
].
